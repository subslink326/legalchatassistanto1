# --------- FastAPI / App config ---------
APP_ENV=development  # development, production, test
APP_PORT=8000
JWT_SECRET=change-me-please-use-a-secure-value-at-least-32-chars

# --------- Database URLs ---------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/legalchatassistant
QDRANT_URL=http://qdrant:6333
ELASTIC_URL=http://elastic:9200

# Database pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --------- LLM / Embeddings ---------
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
# or for local models
LLAMA_MODEL_PATH=/models/llama-3-70b.Q4_K_M.gguf

# Feature flags
ENABLE_TELEMETRY=false
DEMO_MODE=false

# Postgres settings (for docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=legalchatassistant
