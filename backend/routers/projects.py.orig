from uuid import UUID

from fastapi import APIRouter, HTTPException, status, Depends
from sqlalchemy import select, delete
from sqlalchemy.ext.asyncio import AsyncSession
from pydantic import BaseModel, Field

from backend.db.database import get_db
from backend.db import models

router = APIRouter()


# ---------- Pydantic Schemas ----------
class ProjectCreate(BaseModel):
    name: str = Field(..., max_length=255)
    description: str | None = None
    owner_id: UUID | None = None  # TODO: replace with real auth


class ProjectOut(BaseModel):
    id: UUID
    name: str
    description: str | None

    class Config:
        orm_mode = True


# ---------- CRUD Endpoints ----------
@router.post("/", response_model=ProjectOut, status_code=status.HTTP_201_CREATED)
async def create_project(
    body: ProjectCreate,
    db: AsyncSession = Depends(get_db),
):
    owner_id = body.owner_id or UUID("00000000-0000-0000-0000-000000000001")
    project = models.Project(
        name=body.name, description=body.description, owner_id=owner_id
    )
    db.add(project)
    await db.commit()
    await db.refresh(project)
    return project


@router.get("/", response_model=list[ProjectOut])
async def list_projects(
    db: AsyncSession = Depends(get_db),
):
    result = await db.execute(select(models.Project))
    return result.scalars().all()


@router.get("/{project_id}", response_model=ProjectOut)
async def get_project(
    project_id: UUID,
    db: AsyncSession = Depends(get_db),
):
    proj = await db.get(models.Project, project_id)
    if not proj:
        raise HTTPException(status_code=404, detail="Project not found")
    return proj


@router.delete("/{project_id}", status_code=status.HTTP_204_NO_CONTENT)
async def delete_project(
    project_id: UUID,
    db: AsyncSession = Depends(get_db),
):
    await db.execute(delete(models.Project).where(models.Project.id == project_id))
    await db.commit()
