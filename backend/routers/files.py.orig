import os
from uuid import UUID
from pathlib import Path

from fastapi import APIRouter, UploadFile, File, HTTPException, status, Depends
from sqlalchemy.ext.asyncio import AsyncSession

from backend.db.database import get_db
from backend.db import models
from backend.core import chunking, ocr, utils
from backend.db import vector_store, search

router = APIRouter()

STORAGE_ROOT = Path("storage")
STORAGE_ROOT.mkdir(exist_ok=True)


@router.post("/{project_id}/upload", status_code=status.HTTP_201_CREATED)
async def upload_pdf(
    project_id: UUID,
    pdf: UploadFile = File(...),
    db: AsyncSession = Depends(get_db),
):
    # 1) Verify project exists
    project = await db.get(models.Project, project_id)
    if not project:
        raise HTTPException(status_code=404, detail="Project not found")

    # 2) Persist file safely
    safe_name = utils.secure_filename(pdf.filename or "upload.pdf")
    disk_path = STORAGE_ROOT / f"{project_id}_{safe_name}"
    with open(disk_path, "wb") as out:
        out.write(await pdf.read())

    # 3) OCR / extract pages
    pages = ocr.extract_text(disk_path)
    if not any(pages):
        raise HTTPException(400, "PDF had no extractable text")

    # 4) Insert Document row
    doc = models.Document(
        filename=safe_name,
        content_type=pdf.content_type,
        pages=len(pages),
        storage_path=str(disk_path),
        project_id=project_id,
    )
    db.add(doc)
    await db.flush()  # obtain doc.id

    # 5) Chunk & prepare vectors/BM25 docs
    vectors_to_upsert, bm25_to_index = [], []
    for pg_num, page_text in enumerate(pages, start=1):
        chunks = chunking.split_text(page_text, max_tokens=350)
        for ch in chunks:
            chunk_row = models.Chunk(
                page=pg_num,
                page_line=None,
                token_count=chunking.count_tokens(ch),
                text=ch,
                document_id=doc.id,
            )
            db.add(chunk_row)
            await db.flush()
            vectors_to_upsert.append((chunk_row.id, ch))
            bm25_to_index.append(
                {
                    "id": str(chunk_row.id),
                    "project_id": str(project_id),
                    "document_id": str(doc.id),
                    "text": ch,
                    "page": pg_num,
                    "page_line": "",
                    "filename": safe_name,
                }
            )

    await db.commit()

    # 6) Embeddings + BM25 indexing (inline for now; move to worker later)
    ids, texts = zip(*vectors_to_upsert)
    embed_func = utils.get_embedding
    vector_ids = await vector_store.add_texts(
        str(project_id), str(doc.id), texts, embed_func
    )
    await search.index_chunks(bm25_to_index)

    # 7) Store vector IDs back on each Chunk row
    for vec_id, chunk_id in zip(vector_ids, ids):
        chunk = await db.get(models.Chunk, chunk_id)
        chunk.vector_id = vec_id
    await db.commit()

    return {"document_id": doc.id, "chunks": len(ids)}
